int lengthOfLongestSubstring(char* s) {
    int cnt[128];//用来统计字符出现次数
    int left = 0;//窗口左边
    int ans = 0;
    for(int right = 0 ; s[right] ; right++){//右窗口
        char c = s[right];
        cnt[c]++;
        while (cnt[c] > 1){//当有重复字符时左窗口缩小
            cnt[s[left]]--;
            left++;
        }
        ans = (right-left+1) > ans ? (right-left+1):ans;
    }
    return ans;
}
