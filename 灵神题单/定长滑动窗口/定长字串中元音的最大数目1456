int maxVowels(char* s, int k) {
    int cnt = 0;
    int ans = 0;
    for(int i = 0 ; s[i] ; i++){//i表示右窗口
        if(s[i] == 'a'||s[i] =='e'||s[i] =='i'||s[i] =='o'||s[i] =='u'){//右边进入窗口
            cnt++;
        }
        ans = ans > cnt ? ans:cnt;
        if(i-k+1 < 0){//左边还没到窗口
        continue;
        }
        if(s[i-k+1] == 'a'||s[i-k+1] =='e'||s[i-k+1] =='i'||s[i-k+1] =='o'||s[i-k+1] =='u'){//左边出去的是元音
        cnt--;
        }
    }
    return ans;
}
